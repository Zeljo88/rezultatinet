<div data-live-scores
    x-data="{
        activeFilter: 'sve',
        updateLiveTitle() {
            const liveCount = {{ $counts['live'] ?? 0 }};
            if (liveCount > 0) {
                document.title = '\u26BD U\u017DIVO (' + liveCount + ') | rezultati.net';
            } else {
                document.title = 'rezultati.net';
            }
        }
    }"
    x-init="updateLiveTitle()"
    class="w-full max-w-full"
>

    {{-- ══════════════════════════════════════════════════════════════
         LOADING SKELETON
    ══════════════════════════════════════════════════════════════ --}}
    <div wire:loading class="animate-pulse">
        {{-- Filter pills skeleton --}}
        <div class="flex border-b border-[#2a2a2a]">
            @foreach(range(1,4) as $i)
            <div class="flex-1 h-10 bg-[#1a1a1a]"></div>
