        </button>
        <button wire:click="setTab('upcoming')" class="px-4 py-2 rounded-lg text-sm font-bold transition cursor-pointer {{ $tab === 'upcoming' ? 'bg-[#CCFF00] text-black' : 'bg-[#1a1a1a] text-gray-400 hover:text-white border border-[#2a2a2a]' }}">
